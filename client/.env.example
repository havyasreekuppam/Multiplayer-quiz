# Client Environment Variables
# Copy this file to .env.local in the client directory

REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SOCKET_API_URL=http://localhost:5000
REACT_APP_JWT_SECRET=your-client-side-token-storage-key

# Production URLs (uncomment for production build)
# REACT_APP_API_URL=https://api.yourdomain.com/api
# REACT_APP_SOCKET_API_URL=https://yourdomain.com
